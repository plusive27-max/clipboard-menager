{
  "name": "clipboard-manager",
  "version": "1.0.0",
  "description": "A lightweight clipboard history manager",
  "author": "TED",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.yourname.clipboardmanager",
    "productName": "Clipboard Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "style.css",
      "script.js",
      "assets/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "canvas": "^3.2.3"
  }
}
